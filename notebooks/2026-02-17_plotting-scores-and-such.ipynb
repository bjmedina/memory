    "def pca_basis_2d(X):\n",
    "    \"\"\"\n",
    "    Compute orthonormal PCA basis (PC1, PC2) for X and return:\n",
    "      mu: (256,) mean\n",
    "      W:  (2,256) rows are orthonormal directions\n",
    "    \"\"\"\n",
    "    X = np.asarray(X, dtype=float)\n",
    "    mu = X.mean(axis=0, keepdims=True)\n",
    "    Xc = X - mu\n",
    "    _, _, Vt = np.linalg.svd(Xc, full_matrices=False)\n",
    "    W = Vt[:2, :].copy()  # (2,256), already orthonormal up to numerical error\n",
    "\n",
    "    # Explicitly enforce orthonormality (cheap, robust)\n",
    "    W[0] /= (np.linalg.norm(W[0]) + 1e-12)\n",
    "    W[1] -= W[0] * np.dot(W[1], W[0])\n",
    "    W[1] /= (np.linalg.norm(W[1]) + 1e-12)\n",
    "\n",
    "    return mu.ravel(), W\n",
    "\n",
    "\n",
    "@torch.no_grad()\n",
    "def scores_for_points(score_model, x_numpy_256, *, t_value=0.1, batch_size=512, device=\"cuda\"):\n",
    "    \"\"\"\n",
    "    Compute FULL 256-D score for each point x (N,256).\n",
    "    Returns: scores (N,256) numpy\n",
    "    \"\"\"\n",
    "    X = np.asarray(x_numpy_256, dtype=float)\n",
    "    xt = torch.tensor(X, device=device, dtype=torch.float32).view(-1, 1, 1, 256)\n",
    "    t = torch.tensor([t_value], device=device, dtype=torch.float32)\n",
    "\n",
    "    N = xt.shape[0]\n",
    "    out = torch.empty((N, 256), device=device, dtype=torch.float32)\n",
    "\n",
    "    for i in range(0, N, int(batch_size)):\n",
    "        j = min(i + int(batch_size), N)\n",
    "        sb = score_model(xt[i:j], t)\n",
    "        if sb.ndim == 4:\n",
    "            sb = sb.view(j - i, 256)\n",
    "        elif sb.ndim != 2:\n",
    "            raise ValueError(f\"Unexpected score shape: {tuple(sb.shape)}\")\n",
    "        out[i:j] = sb\n",
    "\n",
    "    return out.detach().cpu().numpy()\n",
    "\n",
    "\n",
    "def plot_compatibility_projected(\n",
    "    x_numpy_256,\n",
    "    bpd_textures,\n",
    "    scores256,\n",
    "    *,\n",
    "    arrow_stride=10,\n",
    "    arrow_len=0.8,\n",
    "):\n",
    "    \"\"\"\n",
    "    Same 3 plots as before, but plots (2) uses an ORTHOGONAL 2D PROJECTION (PCA PC1/PC2)\n",
    "    for BOTH the points and the score vectors.\n",
    "\n",
    "    Plot (1) and (3) are still computed in the original 256-D space.\n",
    "    \"\"\"\n",
    "    X = np.asarray(x_numpy_256, dtype=float)\n",
    "    bpd = bpd_textures.detach().cpu().numpy() if torch.is_tensor(bpd_textures) else np.asarray(bpd_textures, dtype=float)\n",
    "    S = np.asarray(scores256, dtype=float)\n",
    "\n",
    "    if X.shape[0] != bpd.shape[0] or X.shape[0] != S.shape[0]:\n",
    "        raise ValueError(f\"Length mismatch: X={X.shape[0]}, bpd={bpd.shape[0]}, S={S.shape[0]}\")\n",
    "\n",
    "    # --- derived quantities in 256D ---\n",
    "    score_norm = np.linalg.norm(S, axis=1)          # ||score|| in 256D\n",
    "    mu_256 = X.mean(axis=0)\n",
    "    radial = np.sum(S * (X - mu_256), axis=1)       # score dot displacement\n",
    "\n",
    "    # ========== (1) BPD vs score norm ==========\n",
    "    plt.figure(figsize=(6.2, 4.6))\n",
    "    plt.scatter(bpd, score_norm, s=12, alpha=0.5)\n",
    "    plt.xlabel(\"bpd_textures (higher = lower likelihood)\")\n",
    "    plt.ylabel(\"||score(x,t)|| (256D)\")\n",
    "    plt.title(\"Compatibility: likelihood vs score magnitude\")\n",
    "    plt.tight_layout()\n",
    "    plt.show()\n",
    "\n",
    "    # ========== (2) PCA-projected scatter colored by BPD + PCA-projected score arrows ==========\n",
    "    mu, W = pca_basis_2d(X)          # mu: (256,), W: (2,256)\n",
    "    X2 = (X - mu[None, :]) @ W.T     # (N,2) projected points\n",
    "    S2 = S @ W.T                     # (N,2) projected score vectors (components along PC1/PC2)\n",
    "\n",
    "    idx = np.arange(len(X2))[::int(arrow_stride)]\n",
    "    P = X2[idx]\n",
    "    U = S2[idx, 0].copy()\n",
    "    V = S2[idx, 1].copy()\n",
    "    mag2 = np.sqrt(U**2 + V**2) + 1e-12\n",
    "    U = (U / mag2) * float(arrow_len)\n",
    "    V = (V / mag2) * float(arrow_len)\n",
    "\n",
    "    plt.figure(figsize=(7.0, 6.0))\n",
    "    sc = plt.scatter(X2[:, 0], X2[:, 1], c=bpd, s=18, alpha=0.7)\n",
    "    plt.colorbar(sc, label=\"bpd_textures\")\n",
    "    plt.quiver(\n",
    "        P[:, 0], P[:, 1], U, V,\n",
    "        angles=\"xy\", scale_units=\"xy\", scale=1.0, pivot=\"mid\",\n",
    "        width=0.004, headwidth=4.5, headlength=6.0, color=\"k\"\n",
    "    )\n",
    "    plt.xlabel(\"PC1\")\n",
    "    plt.ylabel(\"PC2\")\n",
    "    plt.title(\"PCA projection: likelihood color + projected score directions\")\n",
    "    plt.tight_layout()\n",
    "    plt.show()\n",
    "\n",
    "    # ========== (3) BPD vs radial score ==========\n",
    "    plt.figure(figsize=(6.2, 4.6))\n",
    "    plt.scatter(bpd, radial, s=12, alpha=0.5)\n",
    "    plt.axhline(0, linewidth=1)\n",
    "    plt.xlabel(\"bpd_textures\")\n",
    "    plt.ylabel(\"score(x) · (x - mean(x))\")\n",
    "    plt.title(\"Directional sanity check (sign can vary)\")\n",
    "    plt.tight_layout()\n",
    "    plt.show()\n",
    "\n",
    "\n",
    "# -------------------------\n",
    "# Usage (your exact flow)\n",
    "# -------------------------\n",
    "x_numpy_256 = x.squeeze(1).squeeze(1).detach().cpu().numpy()        # (N,256)\n",
    "bpd_textures = compute_likelihood(score_model, input_stats=x, ckpt=ckpt_path)\n",
    "scores256 = scores_for_points(score_model, x_numpy_256, t_value=0.1, batch_size=512, device=\"cuda\")\n",
    "plot_compatibility_projected(x_numpy_256, bpd_textures, scores256, arrow_stride=8, arrow_len=0.9)"
   ]
