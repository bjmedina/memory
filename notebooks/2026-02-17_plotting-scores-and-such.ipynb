   "source": [
    "# ── Directional derivatives of the score along PC1 and PC2 ──\n",
    "# s(x) = ∇_x log p_t(x) in 256D\n",
    "# We want the component along each PC axis:\n",
    "#   (∇log p_t) · w_k  = score · w_k\n",
    "#\n",
    "# BUT the cleaner approach is finite-diff of the scalar log p_t\n",
    "# along each PC direction, which avoids projection noise.\n",
    "#\n",
    "# However since you don't have a cheap scalar log p_t,\n",
    "# use: ∂/∂z_k log p_t = score(x) · w_k  (chain rule)\n",
    "# The issue before was that score(x) has huge components orthogonal\n",
    "# to the PCA plane, but the DOT PRODUCT with w_k isolates the\n",
    "# component we care about.\n",
    "#\n",
    "# The real fix: make sure score_model gets the RIGHT time input\n",
    "# and batch the computation properly.\n",
    "\n",
    "import torch\n",
    "import numpy as np\n",
    "import matplotlib.pyplot as plt\n",
    "from scipy.stats import gaussian_kde\n",
    "from scipy.ndimage import gaussian_filter\n",
    "\n",
    "# ── 1) PCA (same as before) ──\n",
    "X = x.squeeze(1).squeeze(1).detach().cpu().numpy()\n",
    "mu = X.mean(axis=0, keepdims=True)\n",
    "Xc = X - mu\n",
    "_, _, Vt = np.linalg.svd(Xc, full_matrices=False)\n",
    "W = Vt[:2, :]\n",
    "Z = Xc @ W.T\n",
    "\n",
    "# ── 2) Grid ──\n",
    "pad = 0.15\n",
    "r0 = Z[:, 0].ptp(); r1 = Z[:, 1].ptp()\n",
    "n = 80\n",
    "z0 = np.linspace(Z[:, 0].min() - pad*r0, Z[:, 0].max() + pad*r0, n)\n",
    "z1 = np.linspace(Z[:, 1].min() - pad*r1, Z[:, 1].max() + pad*r1, n)\n",
    "G0, G1 = np.meshgrid(z0, z1, indexing=\"xy\")\n",
    "Zg = np.column_stack([G0.ravel(), G1.ravel()])\n",
    "Xg = mu + Zg @ W  # (n*n, 256)\n",
    "\n",
    "# ── 3) KDE for background ──\n",
    "kde = gaussian_kde(Z.T, bw_method=0.15)\n",
    "Q = kde(np.vstack([G0.ravel(), G1.ravel()])).reshape(n, n)\n",
    "\n",
    "# ── 4) Score model: compute directional derivatives via finite differences ──\n",
    "#    This avoids the projection problem entirely.\n",
    "#    f(z0, z1) = log p_t(mu + z0*w0 + z1*w1)\n",
    "#    ∂f/∂z_k ≈ [f(z + eps*e_k) - f(z - eps*e_k)] / (2*eps)\n",
    "#\n",
    "#    We approximate f using the score: f(x+δ) ≈ f(x) + score(x)·δ\n",
    "#    So ∂f/∂z_k = score(x) · w_k   (exact by chain rule)\n",
    "\n",
    "W_t = torch.tensor(W, device=\"cuda\", dtype=torch.float32)  # (2, 256)\n",
    "\n",
    "# Process in batches to avoid OOM\n",
    "batch_size = 512\n",
    "t_value = 0.0000001  # try 0.01, 0.005, 0.05 — smaller = sharper\n",
    "all_dfdz = []\n",
    "\n",
    "for i in range(0, Xg.shape[0], batch_size):\n",
    "    Xg_batch = torch.tensor(Xg[i:i+batch_size], device=\"cuda\", dtype=torch.float32)\n",
    "    Xg_batch = Xg_batch.view(-1, 1, 1, 256)\n",
    "    t_batch = torch.full((Xg_batch.shape[0],), t_value, device=\"cuda\", dtype=torch.float32)\n",
    "    \n",
    "    with torch.no_grad():\n",
    "        s = score_model(Xg_batch, t_batch)  # (B, 1, 1, 256)\n",
    "    \n",
    "    s_flat = s.view(-1, 256)  # (B, 256)\n",
    "    \n",
    "    # Project score onto each PC axis: score · w_k\n",
    "    dfdz = s_flat @ W_t.T  # (B, 2) — this IS ∂(log p)/∂z_k by chain rule\n",
    "    all_dfdz.append(dfdz.cpu().numpy())\n",
    "\n",
    "dfdz = np.concatenate(all_dfdz, axis=0).reshape(n, n, 2)\n",
    "\n",
    "# Smooth to reduce noise from the score model\n",
    "sigma = 2.0  # increase if still noisy\n",
    "U = gaussian_filter(dfdz[:, :, 0], sigma=sigma)\n",
    "V = gaussian_filter(dfdz[:, :, 1], sigma=sigma)\n",
    "\n",
    "# ── 5) Plot ──\n",
    "step = 3\n",
    "UU = U[::step, ::step].copy()\n",
    "VV = V[::step, ::step].copy()\n",
    "XX = G0[::step, ::step]\n",
    "YY = G1[::step, ::step]\n",
    "\n",
    "# Normalize to unit vectors (direction field)\n",
    "mag = np.sqrt(UU**2 + VV**2) + 1e-12\n",
    "UU /= mag; VV /= mag\n",
    "\n",
    "fig, ax = plt.subplots(1, 2, figsize=(12, 5.5), constrained_layout=True)\n",
    "cmap = \"YlOrRd\"\n",
    "extent = [z0.min(), z0.max(), z1.min(), z1.max()]\n",
    "\n",
    "# Left: q(x)\n",
    "ax[0].imshow(Q, origin=\"lower\", cmap=cmap, extent=extent, aspect=\"equal\")\n",
    "ax[0].contour(G0, G1, Q, levels=8, colors=\"k\", linewidths=0.6, alpha=0.5)\n",
    "ax[0].set_title(r\"$q(x)$\", fontsize=26)\n",
    "ax[0].set_xticks([]); ax[0].set_yticks([])\n",
    "\n",
    "# Right: ∇log q(x) from score model\n",
    "ax[1].imshow(Q, origin=\"lower\", cmap=cmap, alpha=0.4, extent=extent, aspect=\"equal\")\n",
    "ax[1].quiver(XX, YY, UU, VV, color=\"k\", angles=\"xy\",\n",
    "             scale=20,           # decrease → bigger arrows\n",
    "             width=0.004,\n",
    "             headwidth=3.5,\n",
    "             headlength=4)\n",
    "ax[1].set_title(r\"$\\nabla \\log q(x)$\", fontsize=26)\n",
    "ax[1].set_xticks([]); ax[1].set_yticks([])\n",
    "\n",
    "plt.savefig(\"score_viz.png\", dpi=200, bbox_inches=\"tight\")\n",
    "plt.show()"
   ]
  },
