    "        weights = _to_numpy_1d(bpd_textures)\n",
    "\n",
    "    if method == \"kde\":\n",
    "        # bw can be \"scott\" or \"silverman\" too; numeric makes it more like your example when < 1\n",
    "        bw_method = bw if isinstance(bw, str) else float(bw)\n",
    "        GX, GY, Z = density_kde(x0, x1, weights=weights, gridsize=gridsize, pad=pad, bw=bw_method)\n",
    "    elif method == \"gmm\":\n",
    "        GX, GY, Z = density_gmm(x0, x1, n_components=5, gridsize=gridsize, pad=pad)\n",
    "    else:\n",
    "        raise ValueError(\"method must be 'kde' or 'gmm'.\")\n",
    "\n",
    "    # Choose contour levels (skip very low tail to get clean rings like the example)\n",
    "    zmax = np.max(Z)\n",
    "    lo = 0.10 * zmax   # raise this (e.g., 0.15) for fewer faint outer contours\n",
    "    levels = np.linspace(lo, zmax, int(n_levels))\n",
    "\n",
    "    fig, ax = plt.subplots(figsize=(7.2, 6.6))\n",
    "\n",
    "    # Filled heatmap (background)\n",
