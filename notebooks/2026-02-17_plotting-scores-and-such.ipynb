   "source": [
    "import numpy as np\n",
    "import matplotlib.pyplot as plt\n",
    "\n",
    "# Optional but recommended: for KDE\n",
    "from scipy.stats import gaussian_kde\n",
    "\n",
    "# Optional alternative: GMM blobs\n",
    "try:\n",
    "    from sklearn.mixture import GaussianMixture\n",
    "    _HAS_SKLEARN = True\n",
    "except Exception:\n",
    "    _HAS_SKLEARN = False\n",
    "\n",
    "\n",
    "def _to_numpy_1d(a):\n",
    "    \"\"\"Convert torch/numpy/list to a contiguous 1D numpy float array.\"\"\"\n",
    "    if hasattr(a, \"detach\"):  # torch tensor\n",
    "        a = a.detach().cpu().numpy()\n",
    "    a = np.asarray(a, dtype=float)\n",
    "    return a.reshape(-1)\n",
    "\n",
    "\n",
    "def _make_grid(x, y, *, pad=0.08, gridsize=250):\n",
    "    \"\"\"Build a square-ish evaluation grid around points with padding.\"\"\"\n",
    "    x = _to_numpy_1d(x)\n",
    "    y = _to_numpy_1d(y)\n",
    "\n",
    "    xmin, xmax = np.min(x), np.max(x)\n",
    "    ymin, ymax = np.min(y), np.max(y)\n",
    "\n",
    "    xr = xmax - xmin\n",
    "    yr = ymax - ymin\n",
    "    xmin -= pad * xr\n",
    "    xmax += pad * xr\n",
    "    ymin -= pad * yr\n",
    "    ymax += pad * yr\n",
    "\n",
    "    xs = np.linspace(xmin, xmax, gridsize)\n",
    "    ys = np.linspace(ymin, ymax, gridsize)\n",
    "    X, Y = np.meshgrid(xs, ys, indexing=\"xy\")\n",
    "    return X, Y\n",
    "\n",
    "\n",
    "def density_kde(x, y, *, weights=None, gridsize=250, pad=0.08, bw=\"scott\"):\n",
    "    \"\"\"\n",
    "    KDE density on a grid.\n",
    "    - weights: optional 1D weights (e.g., bpd_textures) to bias density toward certain points.\n",
    "    - bw: \"scott\", \"silverman\", or a scalar multiplier (e.g., 0.7 for sharper).\n",
    "    Returns: X, Y, Z\n",
    "    \"\"\"\n",
    "    x = _to_numpy_1d(x)\n",
    "    y = _to_numpy_1d(y)\n",
    "    pts = np.vstack([x, y])\n",
    "\n",
    "    w = None\n",
    "    if weights is not None:\n",
    "        w = _to_numpy_1d(weights)\n",
    "        if len(w) != len(x):\n",
    "            raise ValueError(f\"weights length {len(w)} != n points {len(x)}\")\n",
    "        # KDE likes nonnegative weights; shift if needed\n",
    "        w = w - np.min(w)\n",
    "        if np.max(w) > 0:\n",
    "            w = w / np.sum(w)\n",
    "        else:\n",
    "            w = None\n",
    "\n",
    "    kde = gaussian_kde(pts, bw_method=bw, weights=w)\n",
    "\n",
    "    X, Y = _make_grid(x, y, pad=pad, gridsize=gridsize)\n",
    "    grid_pts = np.vstack([X.ravel(), Y.ravel()])\n",
    "    Z = kde(grid_pts).reshape(X.shape)\n",
    "    return X, Y, Z\n",
    "\n",
    "\n",
    "def density_gmm(x, y, *, n_components=5, gridsize=250, pad=0.08, reg_covar=1e-5, seed=0):\n",
    "    \"\"\"\n",
    "    Gaussian Mixture density on a grid (nice for 'blob' aesthetics).\n",
    "    Requires scikit-learn.\n",
    "    Returns: X, Y, Z\n",
    "    \"\"\"\n",
    "    if not _HAS_SKLEARN:\n",
    "        raise ImportError(\"scikit-learn not available; install or use KDE option.\")\n",
    "\n",
    "    x = _to_numpy_1d(x)\n",
    "    y = _to_numpy_1d(y)\n",
    "    data = np.column_stack([x, y])\n",
    "\n",
    "    gmm = GaussianMixture(\n",
    "        n_components=int(n_components),\n",
    "        covariance_type=\"full\",\n",
    "        reg_covar=float(reg_covar),\n",
    "        random_state=int(seed),\n",
    "    )\n",
    "    gmm.fit(data)\n",
    "\n",
    "    X, Y = _make_grid(x, y, pad=pad, gridsize=gridsize)\n",
    "    grid = np.column_stack([X.ravel(), Y.ravel()])\n",
    "    logp = gmm.score_samples(grid)\n",
    "    Z = np.exp(logp).reshape(X.shape)\n",
    "    return X, Y, Z\n",
    "\n",
    "\n",
    "def plot_q_like_density(\n",
    "    x_numpy,\n",
    "    bpd_textures=None,\n",
    "    *,\n",
    "    method=\"kde\",          # \"kde\" or \"gmm\"\n",
    "    weight_by_bpd=False,   # if True, KDE uses bpd as weights\n",
    "    bw=0.75,               # KDE bandwidth multiplier; lower -> sharper blobs\n",
    "    n_levels=7,            # number of contour lines\n",
    "    gridsize=260,\n",
    "    pad=0.10,\n",
    "    title=r\"$q(x)$\",\n",
