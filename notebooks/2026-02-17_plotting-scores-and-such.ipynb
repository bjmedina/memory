    "        extent=[GX.min(), GX.max(), GY.min(), GY.max()],\n",
    "        aspect=\"auto\",\n",
    "    )\n",
    "\n",
    "    # Contour lines\n",
    "    ax.contour(GX, GY, Z, levels=levels)\n",
    "\n",
    "    if show_points:\n",
    "        ax.scatter(x0, x1, s=point_size, alpha=alpha_points)\n",
    "\n",
    "    ax.set_xlabel(\"PC 1\")\n",
    "    ax.set_ylabel(\"PC 2\")\n",
    "\n",
    "    # Big math title like your example\n",
    "    ax.set_title(title, fontsize=22, pad=22)\n",
    "    ax.set_xticks([])\n",
    "    ax.set_yticks([])\n",
    "\n",
    "    fig.tight_layout()\n",
