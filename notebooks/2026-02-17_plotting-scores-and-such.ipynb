    "def _to_numpy_1d(a):\n",
    "    \"\"\"Convert torch/numpy/list to a contiguous 1D numpy float array.\"\"\"\n",
    "    if hasattr(a, \"detach\"):  # torch tensor\n",
    "        a = a.detach().cpu().numpy()\n",
    "    a = np.asarray(a, dtype=float)\n",
    "    return a.reshape(-1)\n",
    "    \n",
    "def plot_xy_colored_by_bpd(x_numpy, bpd_textures, *, s=40, alpha=0.85, cmap=\"viridis\"):\n",
    "    \"\"\"\n",
    "    Scatter plot: x_numpy[:,0] vs x_numpy[:,1], colored by bpd_textures.\n",
    "    Returns (fig, ax).\n",
    "    \"\"\"\n",
    "    X = np.asarray(x_numpy)\n",
    "    if X.ndim != 2 or X.shape[1] < 2:\n",
    "        raise ValueError(f\"x_numpy must be 2D with at least 2 columns; got shape {X.shape}\")\n",
    "\n",
    "    x0 = _to_numpy_1d(X[:, 0])\n",
    "    x1 = _to_numpy_1d(X[:, 1])\n",
    "    bpd = _to_numpy_1d(bpd_textures)\n",
    "\n",
    "    if not (len(x0) == len(x1) == len(bpd)):\n",
    "        raise ValueError(f\"Length mismatch: len(x0)={len(x0)}, len(x1)={len(x1)}, len(bpd)={len(bpd)}\")\n",
    "\n",
    "    fig, ax = plt.subplots(figsize=(6.5, 5.5))\n",
    "    sc = ax.scatter(x0, x1, c=bpd, s=s, alpha=alpha, cmap=cmap)\n",
    "    cb = fig.colorbar(sc, ax=ax)\n",
    "    cb.set_label(\"bpd_textures\")\n",
    "\n",
    "    ax.set_xlabel(\"x_numpy[:, 0]\")\n",
    "    ax.set_ylabel(\"x_numpy[:, 1]\")\n",
    "    ax.set_title(\"x_numpy[:,0] vs x_numpy[:,1] colored by bpd_textures\")\n",
    "    ax.grid(True, alpha=0.25)\n",
    "    fig.tight_layout()\n",
    "    return fig, ax\n"
   ]
