    "def run_sigma_sweep(sigma_name, sigma_grid, fixed_sigmas, exps_by_isi,\n",
    "                    isi_to_hc_idx, human_curve, N_MC, t_step, noise_mode,\n",
    "                    metric, X, name_to_idx, base_seed=0):\n",
    "    \"\"\"Sweep one sigma over sigma_grid; for each value run N_MC reps.\n",
    "    Returns list of dicts with sigma_value, mse_mean, mse_std, dprime_mean, dprime_std.\n",
    "    \"\"\"\n",
<<<<<<< HEAD
    "    hit_scores = np.asarray(hit_scores)\n",
    "    fa_scores  = np.asarray(fa_scores)\n",
    "\n",
    "    thresholds = np.unique(np.concatenate([hit_scores, fa_scores]))\n",
    "\n",
    "    dprimes = []\n",
    "\n",
    "    for thr in thresholds:\n",
    "        hit_rate = np.mean(hit_scores <= thr)\n",
    "        fa_rate  = np.mean(fa_scores  <= thr)\n",
    "\n",
    "        # avoid infinities\n",
    "        hit_rate = np.clip(hit_rate, eps, 1 - eps)\n",
    "        fa_rate  = np.clip(fa_rate,  eps, 1 - eps)\n",
    "\n",
    "        dprimes.append(norm.ppf(hit_rate) - norm.ppf(fa_rate))\n",
    "\n",
    "    return np.asarray(dprimes)\n",
    "\n",
    "def bootstrap_auc(hit_scores, fa_scores, n_boot=1000):\n",
    "    y_true = np.concatenate([\n",
    "        np.ones(len(hit_scores)),\n",
    "        np.zeros(len(fa_scores)),\n",
    "    ])\n",
    "    scores = np.concatenate([hit_scores, fa_scores])\n",
    "\n",
    "    N = len(scores)\n",
    "    aucs = []\n",
    "\n",
    "    for _ in range(n_boot):\n",
    "        idx = np.random.choice(N, N, replace=True)\n",
    "        aucs.append(\n",
    "            roc_auc_score(y_true[idx], -scores[idx])\n",
    "        )\n",
    "\n",
    "    return np.mean(aucs), np.std(aucs)"
   ]
